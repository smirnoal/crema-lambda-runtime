{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "APIGatewayCustomAuthorizerResponse",
  "type": "object",
  "required": [ "principalId", "policyDocument" ],
  "properties": {
    "principalId": {
      "type": "string"
    },
    "policyDocument": {
      "type": "object",
      "required": [ "Version", "Statement" ],
      "properties": {
        "Version": {
          "type": "string"
        },
        "Statement": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Action": {
                "type": "string"
              },
              "Effect": {
                "type": "string"
              },
              "Resource": {
                "oneOf": [ {
                  "type": "string"
                }, {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                } ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "usageIdentifierKey": {
      "type": "string"
    }
  },
  "additionalProperties": false
}