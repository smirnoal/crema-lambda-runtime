{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudWatchCompositeAlarmEvent",
  "type": "object",
  "properties": {
    "source": {
      "type": "string"
    },
    "alarmArn": {
      "type": "string"
    },
    "accountId": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "alarmData": {
      "$ref": "#/definitions/AlarmData"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AlarmData": {
      "type": "object",
      "properties": {
        "alarmName": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/State"
        },
        "previousState": {
          "$ref": "#/definitions/PreviousState"
        },
        "configuration": {
          "$ref": "#/definitions/Configuration"
        }
      },
      "additionalProperties": false
    },
    "State": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "reasonData": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PreviousState": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "reasonData": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "actionsSuppressedBy": {
          "type": "string"
        },
        "actionsSuppressedReason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Configuration": {
      "type": "object",
      "properties": {
        "alarmRule": {
          "type": "string"
        },
        "actionsSuppressor": {
          "type": "string"
        },
        "actionsSuppressorWaitPeriod": {
          "type": "integer"
        },
        "actionsSuppressorExtensionPeriod": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  }
}