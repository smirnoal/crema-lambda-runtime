{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudWatchMetricAlarmEvent",
  "type": "object",
  "properties": {
    "source": {
      "type": "string"
    },
    "alarmArn": {
      "type": "string"
    },
    "accountId": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "alarmData": {
      "$ref": "#/definitions/AlarmData"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AlarmData": {
      "type": "object",
      "properties": {
        "alarmName": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/State"
        },
        "previousState": {
          "$ref": "#/definitions/PreviousState"
        },
        "configuration": {
          "$ref": "#/definitions/Configuration"
        }
      },
      "additionalProperties": false
    },
    "State": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PreviousState": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "reasonData": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Configuration": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Metric"
          }
        }
      },
      "additionalProperties": false
    },
    "Metric": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "metricStat": {
          "$ref": "#/definitions/MetricStat"
        },
        "returnData": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "MetricStat": {
      "type": "object",
      "properties": {
        "metric": {
          "$ref": "#/definitions/MetricDetail"
        },
        "period": {
          "type": "integer"
        },
        "stat": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MetricDetail": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}